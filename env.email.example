# Copy these lines into your .env and fill with real SMTP credentials.
# Used by the contact form to email both the store and the customer.

email.protocol = smtp
email.fromEmail = cellaviesupport@gmail.com
email.fromName = CellaVie
email.recipients = cellaviesupport@gmail.com
email.SMTPHost = smtp.example.com
email.SMTPUser = your-smtp-username
email.SMTPPass = your-smtp-password
email.SMTPPort = 587
email.SMTPCrypto = tls
email.mailType = html
